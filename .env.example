# Required: OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Required: Telegram bot token (from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Required: Your Telegram numeric user ID (from @userinfobot on Telegram)
TELEGRAM_USER_ID=123456789

# Optional: Enable auto-voice for scheduled check-ins and buffer alerts (true/false)
VOICE_AUTO_ENABLED=false

# Optional: Dashboard API configuration
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8085
DASHBOARD_DATA_DIR=data
DASHBOARD_STATIC_DIR=dashboard
DASHBOARD_REFRESH_INTERVAL=30000
